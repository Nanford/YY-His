# 复制为 .env.local 并填入真实密钥（.env.local 不入库）。
# 所有密钥只在服务端使用；未配置时语音链路自动降级（纯字幕 + 按钮/文字作答），流程仍可完整演示。

# DeepSeek：回答归一化（JSON mode）。缺失时归一化走规则兜底。
DEEPSEEK_API_KEY=

# 火山引擎语音技术（豆包 TTS + 大模型录音识别共用一套密钥）
VOLC_APP_ID=
VOLC_ACCESS_TOKEN=
# 可选：豆包 TTS 音色（需在火山控制台开通对应音色，2.0 音色走 seed-tts-2.0 资源）
VOLC_TTS_VOICE=zh_female_xiaohe_uranus_bigtts
# 可选：TTS 模型资源 ID（默认 seed-tts-2.0；声音复刻音色用 seed-icl-2.0）
# VOLC_TTS_RESOURCE_ID=seed-tts-2.0

# 数字人形象：sdk=商用数字人 SDK（商务开通后接入）；fallback=内置 2D 降级形象
AVATAR_MODE=fallback
