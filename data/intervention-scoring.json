  "interventions": [
    {
      "code": "M01",
      "category": "运动干预",
      "name": "扶椅坐站",
      "mediaType": "video",
      "mediaSrc": "/interventions/videos/M01.mp4",
      "mediaAvailable": false,
      "sourceFile": null,
      "text": "坐在稳固椅子前部，双脚踩稳，身体稍向前倾后缓慢站起，再缓慢坐下，每次5～10个，每周训练2～3次。"
    },
    {
      "code": "M02",
      "category": "运动干预",
      "name": "坐位伸膝",
      "mediaType": "video",
      "mediaSrc": "/interventions/videos/M02.mp4",
      "mediaAvailable": false,
      "sourceFile": null,
      "text": "坐在椅子上，将一侧小腿缓慢伸直，保持2～3秒后放下，左右交替，每侧8～12次。"
    },
    {
      "code": "M03",
      "category": "运动干预",
      "name": "扶椅提踵",
      "mediaType": "video",
      "mediaSrc": "/interventions/videos/M03.mp4",
      "mediaAvailable": false,
      "sourceFile": null,
      "text": "双手扶住椅背，缓慢抬起脚后跟，再缓慢落下，每次10～15个，主要训练小腿力量。"
    },
    {
      "code": "M04",
      "category": "运动干预",
      "name": "扶椅侧抬腿",
      "mediaType": "video",
      "mediaSrc": "/interventions/videos/M04.mp4",
      "mediaAvailable": false,
      "sourceFile": null,
      "text": "双手扶椅，将一侧腿缓慢向外侧抬起，保持身体直立，每侧8～12次。"
    },
    {
      "code": "M05",
      "category": "运动干预",
      "name": "扶椅后抬腿",
      "mediaType": "video",
      "mediaSrc": "/interventions/videos/M05.mp4",
      "mediaAvailable": false,
      "sourceFile": null,
      "text": "双手扶椅，一侧腿缓慢向后伸展，避免身体前倾，每侧8～12次。"
    },
    {
      "code": "M06",
      "category": "运动干预",
      "name": "坐位抬腿踏步",
      "mediaType": "video",
      "mediaSrc": "/interventions/videos/M06.mp4",
      "mediaAvailable": false,
      "sourceFile": null,
      "text": "坐在椅子上，左右交替抬起膝盖，连续进行1～3分钟，改善下肢力量和活动耐量。"
    },
    {
      "code": "M07",
      "category": "运动干预",
      "name": "墙壁俯卧撑",
      "mediaType": "video",
      "mediaSrc": "/interventions/videos/M07.mp4",
      "mediaAvailable": false,
      "sourceFile": null,
      "text": "面对墙壁站立，双手撑墙，屈肘靠近墙面后再推回，每次8～12个。"
    },
    {
      "code": "M08",
      "category": "运动干预",
      "name": "弹力带划船",
      "mediaType": "video",
      "mediaSrc": "/interventions/videos/M08.mp4",
      "mediaAvailable": false,
      "sourceFile": null,
      "text": "坐位或站位握住弹力带，双手向后拉，使肩胛骨靠近，再缓慢还原，每次8～12个。"
    },
    {
      "code": "M09",
      "category": "运动干预",
      "name": "脚跟对脚尖站立",
      "mediaType": "video",
      "mediaSrc": "/interventions/videos/M09.mp4",
      "mediaAvailable": false,
      "sourceFile": null,
      "text": "一只脚放在另一只脚前方，扶椅保持10～30秒，左右脚交替进行。"
    },
    {
      "code": "M10",
      "category": "运动干预",
      "name": "扶椅重心转移",
      "mediaType": "video",
      "mediaSrc": "/interventions/videos/M10.mp4",
      "mediaAvailable": false,
      "sourceFile": null,
      "text": "双手扶椅，身体重心缓慢向左、向右移动，每侧重复8～10次。"
    },
    {
      "code": "M11",
      "category": "运动干预",
      "name": "原地踏步",
      "mediaType": "video",
      "mediaSrc": "/interventions/videos/M11.mp4",
      "mediaAvailable": false,
      "sourceFile": null,
      "text": "扶住椅背或墙面，左右交替抬腿踏步，每次1～5分钟，根据体力逐步增加。"
    },
    {
      "code": "M12",
      "category": "运动干预",
      "name": "步行训练",
      "mediaType": "video",
      "mediaSrc": "/interventions/videos/M12.mp4",
      "mediaAvailable": false,
      "sourceFile": null,
      "text": "选择安全平整的路线，以能够正常说话的速度步行10～30分钟，每周进行3～5次。"
    },
